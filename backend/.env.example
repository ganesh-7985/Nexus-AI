# LLM Provider — pick one
LLM_API_TYPE=vertex         # openai | gemini | vertex | anthropic
LLM_API_KEY=vertex-uses-adc
LLM_MODEL=publishers/google/models/gemini-2.5-flash
LLM_BASE_URL=               # leave blank for default endpoints

# GCP / Vertex AI settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Investment budget (max dollars spent per project run)
INVESTMENT=3.0
N_ROUND=5

# Supabase — persistent storage + auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
